              "exec",
              "app_server_ws"
            ],
            "default": "app_server_ws"
          },
          "kind": {
            "type": "string",
            "enum": [
              "new",
              "resume"
            ],
            "default": "new"
          },
          "session_id": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "reasoning_effort": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "xhigh"
            ]
          },
          "sandbox": {
            "type": "string",
            "enum": [
              "read-only",
              "workspace-write",
              "danger-full-access"
            ]
          },
          "approvals": {
            "type": "string"
          },
          "search": {
            "type": "boolean",
            "default": false
          },
          "use_exec": {
            "type": "boolean",
            "default": true
          },
          "app_server_url": {
            "type": "string"
          },
          "app_server_bearer_token": {
            "type": "string"
          },
          "include_events": {
            "type": "boolean",
            "default": false
          },
          "max_events": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500,
            "default": 50
          },
          "diff_mode": {
            "type": "string",
            "enum": [
              "live",
              "final_only",
              "off"
            ],
            "default": "live"
          }
        },
        "additionalProperties": false
      },
