  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getGatewayHealth",
        "summary": "Get gateway health",
        "responses": {
          "200": {
            "description": "Gateway health response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/capabilities": {
      "get": {
        "operationId": "getCapabilities",
        "summary": "Get dynamic function catalog for current gateway runtime",
        "responses": {
          "200": {
            "description": "Dynamic capabilities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilitiesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/context/options": {
      "get": {
        "operationId": "getContextOptions",
        "summary": "Get project/thread selection options with most recent context previews",
        "parameters": [
          {
            "name": "project_path",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "project_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 20
            }
          },
          {
            "name": "thread_limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Context options",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContextOptionsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/context/switch": {
      "post": {
        "operationId": "switchProjectContext",
        "summary": "Switch project context and pick thread policy (reuse latest or create new)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SwitchProjectContextRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Context switched",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SwitchProjectContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/codex/jobs": {
      "post": {
        "operationId": "createCodexJob",
        "summary": "Submit long-running Codex task and return immediately with job id",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CodexJobRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CodexJobStatus"
                }
              }
            }
          }
        }
      }
    },
    "/codex/jobs/{job_id}": {
      "get": {
        "operationId": "getCodexJob",
        "summary": "Get async Codex job status",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CodexJobStatus"
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    },
    "/codex/jobs/{job_id}/approval": {
      "post": {
        "operationId": "postCodexJobApproval",
        "summary": "Submit decision for a pending approval request in an async Codex job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CodexJobApprovalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Approval decision accepted"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Job not found"
          },
          "409": {
            "description": "No pending approval or request mismatch"
          }
        }
      }
    },
    "/codex/jobs/{job_id}/result": {
      "get": {
        "operationId": "getCodexJobResult",
        "summary": "Get async Codex job final result",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CodexJobResult"
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          },
          "409": {
            "description": "Job is still running"
          },
          "502": {
            "description": "Job failed"
          }
        }
      }
    },
    "/codex/jobs/{job_id}/events": {
      "get": {
        "operationId": "getCodexJobEvents",
        "summary": "Get buffered job events (delta by sequence)",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "thread_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since_seq",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5000,
              "default": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Buffered events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CodexJobEventsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Job not found"
          }
        }
      }
    }
  }
}
