{
  "openapi": "3.1.0",
  "info": {
    "title": "Codex Gateway API",
    "description": "Gateway for Codex health checks and task execution.",
    "version": "1.2.1"
  },
  "servers": [
    {
      "url": "https://<GATEWAY_HOST>"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "ManagedAppServerStatus": {
        "type": "object",
        "properties": {
          "started_by_gateway": { "type": "boolean" },
          "running": { "type": "boolean" },
          "pid": { "type": ["integer", "null"] },
          "listen_url": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "repo": { "type": "string" },
          "app_server_url": { "type": "string" },
          "managed_app_server": {
            "$ref": "#/components/schemas/ManagedAppServerStatus"
          }
        },
        "required": ["status"],
        "additionalProperties": true
      },
      "CodexRequest": {
        "type": "object",
        "properties": {
          "backend": {
            "type": "string",
            "enum": ["exec", "app_server_ws"],
            "default": "app_server_ws"
          },
          "kind": {
            "type": "string",
            "enum": ["new", "resume"],
            "default": "new"
          },
          "session_id": { "type": "string" },
          "prompt": { "type": "string" },
          "cwd": { "type": "string" },
          "profile": { "type": "string" },
          "model": { "type": "string" },
          "reasoning_effort": {
            "type": "string",
            "enum": ["low", "medium", "high", "xhigh"]
          },
          "sandbox": {
            "type": "string",
            "enum": ["read-only", "workspace-write", "danger-full-access"]
          },
          "approvals": { "type": "string" },
          "search": { "type": "boolean", "default": false },
          "use_exec": { "type": "boolean", "default": true },
          "app_server_url": { "type": "string" },
          "app_server_bearer_token": { "type": "string" },
          "include_events": { "type": "boolean", "default": false },
          "max_events": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500,
            "default": 50
          },
          "diff_mode": {
            "type": "string",
            "enum": ["live", "final_only", "off"],
            "default": "live"
          }
        },
        "additionalProperties": false
      },
      "TurnInfo": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "error": {
            "type": ["object", "null"],
            "properties": {},
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "EventItem": {
        "type": "object",
        "properties": {
          "id": { "type": ["integer", "string", "null"] },
          "method": { "type": ["string", "null"] },
          "params": {
            "type": ["object", "null"],
            "properties": {},
            "additionalProperties": true
          },
          "result": {
            "type": ["object", "null"],
            "properties": {},
            "additionalProperties": true
          },
          "error": {
            "type": ["object", "null"],
            "properties": {},
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "CodexResponse": {
        "type": "object",
        "properties": {
          "backend": { "type": "string" },
          "app_server_url": { "type": "string" },
          "thread_id": { "type": "string" },
          "assistant_text": { "type": "string" },
          "turn": { "$ref": "#/components/schemas/TurnInfo" },
          "command": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" },
          "exit_code": { "type": "integer" },
          "stdout_truncated": { "type": "boolean" },
          "stderr_truncated": { "type": "boolean" },
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EventItem" }
          }
        },
        "additionalProperties": true
      },
      "CodexJobRequest": {
        "type": "object",
        "properties": {
          "payload": { "$ref": "#/components/schemas/CodexRequest" }
        },
        "required": ["payload"],
        "additionalProperties": false
      },
      "CodexJobApprovalRequest": {
        "type": "object",
        "properties": {
          "request_id": { "type": ["integer", "string"] },
          "decision": {
            "type": "string",
            "enum": ["approve_once", "approve_all_similar", "deny", "guidance"]
          },
          "guidance_text": { "type": "string" },
          "scope_hint": { "type": "string" }
        },
        "required": ["request_id", "decision"],
        "additionalProperties": false
      },
      "CodexJobStatus": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" },
          "status": { "type": "string", "enum": ["queued", "running", "waiting_approval", "completed", "failed"] },
          "created_at": { "type": ["string", "null"] },
          "started_at": { "type": ["string", "null"] },
          "updated_at": { "type": ["string", "null"] },
          "completed_at": { "type": ["string", "null"] },
          "poll_after_seconds": { "type": "integer" },
          "next_poll_after_at": { "type": ["string", "null"] },
          "retry_after_seconds": { "type": "integer" },
          "thread_id": { "type": ["string", "null"] },
          "last_event_method": { "type": ["string", "null"] },
          "last_update_text": { "type": ["string", "null"] },
          "approval_required": { "type": "boolean" },
          "approval_request": { "type": ["object", "null"], "properties": {}, "additionalProperties": true },
          "approval_policy_count": { "type": "integer" },
          "diff_mode": { "type": ["string", "null"] },
          "diff_live_available": { "type": "boolean" },
          "diff_live_version": { "type": "integer" },
          "diff_final_available": { "type": "boolean" },
          "diff_hint": { "type": ["string", "null"] },
          "diagnostic_diff_available": { "type": "boolean" },
          "error": { "type": ["object", "null"], "properties": {}, "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "CodexJobResult": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": ["string", "null"] },
          "started_at": { "type": ["string", "null"] },
          "updated_at": { "type": ["string", "null"] },
          "completed_at": { "type": ["string", "null"] },
          "poll_after_seconds": { "type": "integer" },
          "thread_id": { "type": ["string", "null"] },
          "error": { "type": ["object", "null"], "properties": {}, "additionalProperties": true },
          "result": { "$ref": "#/components/schemas/CodexResponse" }
        },
        "additionalProperties": true
      },
      "CodexJobLiveDiffResponse": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" },
          "status": { "type": ["string", "null"] },
          "diff_mode": { "type": ["string", "null"] },
          "diff_live_available": { "type": "boolean" },
          "diff_live_version": { "type": "integer" },
          "updates": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        },
        "additionalProperties": true
      },
      "CodexJobFinalDiffResponse": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" },
          "status": { "type": ["string", "null"] },
          "has_diff": { "type": "boolean" },
          "mode": { "type": ["string", "null"] },
          "view": { "type": ["string", "null"] },
          "diff": { "type": ["string", "null"] },
          "files": {
            "type": ["array", "null"],
            "items": { "type": "object", "additionalProperties": true }
          }
        },
        "additionalProperties": true
      },
      "CodexJobDebugTraceResponse": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" },
          "status": { "type": ["string", "null"] },
          "trace_count": { "type": "integer" },
          "trace": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        },
        "additionalProperties": true
      },
      "CodexInProgressResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["in_progress"] },
          "message": { "type": "string" },
          "job_id": { "type": "string" },
          "job": { "$ref": "#/components/schemas/CodexJobStatus" }
        },
        "required": ["status", "job_id"],
        "additionalProperties": true
      },
      "ProjectItem": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "cwd": { "type": "string" },
          "name": { "type": "string" },
          "thread_count": { "type": "integer" },
          "last_updated_at": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      },
      "ProjectsResponse": {
        "type": "object",
        "properties": {
          "state_db": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProjectItem" }
          }
        },
        "additionalProperties": true
      },
      "ThreadItem": {
        "type": "object",
        "properties": {
          "thread_id": { "type": "string" },
          "short_thread_id": { "type": "string" },
          "project_name": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "first_user_message": { "type": "string" },
          "preview": { "type": "string" },
          "display_name": { "type": "string" },
          "cwd": { "type": "string" },
          "created_at": { "type": ["string", "null"] },
          "updated_at": { "type": ["string", "null"] },
          "model_provider": { "type": ["string", "null"] },
          "model": { "type": ["string", "null"] },
          "reasoning_effort": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      },
      "ThreadsResponse": {
        "type": "object",
        "properties": {
          "state_db": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ThreadItem" }
          }
        },
        "additionalProperties": true
      },
      "ThreadByIdResponse": {
        "type": "object",
        "properties": {
          "state_db": { "type": "string" },
          "thread": { "$ref": "#/components/schemas/ThreadItem" }
        },
        "additionalProperties": true
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getGatewayHealth",
        "summary": "Get gateway health",
        "responses": {
          "200": {
            "description": "Gateway health response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/codex": {
      "post": {
        "operationId": "runCodexTask",
        "summary": "Run Codex task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CodexRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Codex execution result",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/CodexResponse" },
                    { "$ref": "#/components/schemas/CodexInProgressResponse" }
                  ]
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Internal error" }
        }
      }
    },
    "/codex/jobs": {
      "post": {
        "operationId": "createCodexJob",
        "summary": "Submit long-running Codex task and return immediately with job id",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CodexJobRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CodexJobStatus" }
              }
            }
          }
        }
      }
    },
    "/codex/jobs/{job_id}": {
      "get": {
        "operationId": "getCodexJob",
        "summary": "Get async Codex job status",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CodexJobStatus" }
              }
            }
          },
          "404": { "description": "Job not found" }
        }
      }
    },
    "/codex/jobs/{job_id}/approval": {
      "post": {
        "operationId": "postCodexJobApproval",
        "summary": "Submit decision for a pending approval request in an async Codex job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CodexJobApprovalRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Approval decision accepted" },
          "400": { "description": "Bad request" },
          "404": { "description": "Job not found" },
          "409": { "description": "No pending approval or request mismatch" }
        }
      }
    },
    "/codex/jobs/{job_id}/result": {
      "get": {
        "operationId": "getCodexJobResult",
        "summary": "Get async Codex job final result",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CodexJobResult" }
              }
            }
          },
          "404": { "description": "Job not found" },
          "409": { "description": "Job is still running" },
          "502": { "description": "Job failed" }
        }
      }
    },
    "/codex/jobs/{job_id}/diff/live": {
      "get": {
        "operationId": "getCodexJobDiffLive",
        "summary": "Get live incremental diff updates for an async Codex job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "since_version",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "default": 0 }
          },
          {
            "name": "max_chars",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1000, "maximum": 2000000, "default": 200000 }
          }
        ],
        "responses": {
          "200": {
            "description": "Live diff updates (if available)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CodexJobLiveDiffResponse" }
              }
            }
          },
          "404": { "description": "Job not found" }
        }
      }
    },
    "/codex/jobs/{job_id}/diff/final": {
      "get": {
        "operationId": "getCodexJobDiffFinal",
        "summary": "Get final diff for an async Codex job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "view",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["raw", "split"], "default": "raw" }
          },
          {
            "name": "max_chars",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1000, "maximum": 2000000, "default": 200000 }
          }
        ],
        "responses": {
          "200": {
            "description": "Final diff (or diagnostic diff on failure)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CodexJobFinalDiffResponse" }
              }
            }
          },
          "404": { "description": "Job not found" },
          "409": { "description": "Final diff not ready" }
        }
      }
    },
    "/codex/jobs/{job_id}/debug-trace": {
      "get": {
        "operationId": "getCodexJobDebugTrace",
        "summary": "Get compact debug trace of WS events captured for a Codex job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 2000, "default": 200 }
          }
        ],
        "responses": {
          "200": {
            "description": "Debug trace",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CodexJobDebugTraceResponse" }
              }
            }
          },
          "404": { "description": "Job not found" }
        }
      }
    },
    "/projects": {
      "get": {
        "operationId": "getProjects",
        "summary": "List projects derived from Codex threads, grouped by cwd",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 5000, "default": 200 }
          },
          {
            "name": "existing_only",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": true },
            "description": "Return only projects whose cwd exists on this host"
          }
        ],
        "responses": {
          "200": {
            "description": "Projects list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectsResponse" }
              }
            }
          }
        }
      }
    },
    "/threads": {
      "get": {
        "operationId": "getThreads",
        "summary": "List threads sorted by last update, optionally filtered by project cwd",
        "parameters": [
          {
            "name": "cwd",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Exact project folder path"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 5000, "default": 100 }
          },
          {
            "name": "existing_only",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": true },
            "description": "Return only threads whose cwd exists on this host"
          }
        ],
        "responses": {
          "200": {
            "description": "Threads list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ThreadsResponse" }
              }
            }
          }
        }
      }
    },
    "/threads/{thread_id}": {
      "get": {
        "operationId": "getThreadById",
        "summary": "Get single thread metadata",
        "parameters": [
          {
            "name": "thread_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Thread metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ThreadByIdResponse" }
              }
            }
          },
          "404": { "description": "Thread not found" }
        }
      }
    }
  }
}
