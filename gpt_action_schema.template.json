            "type": "string"
          },
          "app_server_url": {
            "type": "string"
          },
          "managed_app_server": {
            "$ref": "#/components/schemas/ManagedAppServerStatus"
          }
        },
        "required": [
          "status"
        ],
        "additionalProperties": true
      },
      "CodexRequest": {
        "type": "object",
